// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ArticleLanguage {
  zh
  en
}

enum ContentFormat {
  markdown
  notesaw
}

enum ArticleStatus {
  draft
  published
  review
}

enum AiTaskType {
  review
  translate
  generate
  scan
  discover
}

enum WikiStatus {
  creating
  unreviewed
  reviewed
  deleted
}

enum AiTaskStatus {
  pending
  processing
  completed
  failed
}

enum DiscoveryStatus {
  pending
  approved
  rejected
  generated
  failed
}

enum ProposalStatus {
  pending
  approved
  rejected
}

model Article {
  id          String          @id @default(uuid())
  slug        String
  title       String
  language    ArticleLanguage
  contentType ContentFormat   @default(markdown)
  contentPath String
  summary     String?
  tags        String[]
  status      ArticleStatus   @default(draft)
  accessGroup String[]
  publishedAt DateTime?
  updatedAt   DateTime        @updatedAt
  defaultImageAccessGroup String[] @default([])
  changelog        String?
  renderedContent  String?
  author           String          @default("博主")
  viewCount        Int             @default(0)
  likes            Int             @default(0)
  charCount        Int             @default(0)

  isAITranslated  Boolean         @default(false)
  isHidden        Boolean         @default(false)
  isPinned        Boolean         @default(false)

  // 翻译版本绑定：若此记录是 AI 翻译版本，指向原文章
  originalId      String?
  originalArticle Article?  @relation("ArticleTranslation", fields: [originalId], references: [id])
  translations    Article[] @relation("ArticleTranslation")

  // 草稿绑定：若此记录是草稿，指向它所属的已发布文章
  draftOfId String?
  draftOf   Article?  @relation("DraftRelation", fields: [draftOfId], references: [id])
  drafts    Article[] @relation("DraftRelation")

  wikiLinks          ArticleWikiLink[]
  imageOverrides     ArticleImageOverride[]
  comments           Comment[]
  aiTasks            AiTask[]
  discoveries        WikiDiscovery[]
  proposals          WikiProposal[]

  @@unique([slug, language])
  @@unique([originalId, language])
}

model ArticleImageOverride {
  id          String   @id @default(cuid())
  articleId   String
  filename    String
  accessGroup String[]

  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, filename])
}

model WikiEntry {
  id          String          @id @default(uuid())
  name        String
  aliases     String[]
  language    ArticleLanguage
  contentType ContentFormat   @default(markdown)
  definition  String
  contentPath String
  tags        String[]
  type        String          @default("concept")
  accessGroup String[]
  status      WikiStatus      @default(creating)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  articleLinks  ArticleWikiLink[]
  discoveries   WikiDiscovery[]

  @@unique([name, language])
}

model ArticleWikiLink {
  id          String    @id @default(uuid())
  articleId   String
  wikiEntryId String
  detectedAt  DateTime  @default(now())

  article    Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  wikiEntry  WikiEntry @relation(fields: [wikiEntryId], references: [id], onDelete: Cascade)

  @@unique([articleId, wikiEntryId])
}

model AiTask {
  id          String        @id @default(uuid())
  type        AiTaskType
  status      AiTaskStatus  @default(pending)
  input       Json
  output      Json?
  error       String?
  createdAt   DateTime      @default(now())
  completedAt DateTime?

  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String   @id @default(uuid())
  articleId  String
  authorName String
  content    String
  isHidden   Boolean  @default(false)
  createdAt  DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  roles         String[]  @default(["user"])
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
  proposals     WikiProposal[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WikiProposal {
  id              String         @id @default(uuid())
  name            String
  sourceArticleId String?
  sourceContext   String?
  status          ProposalStatus @default(pending)
  createdAt       DateTime       @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  article  Article? @relation(fields: [sourceArticleId], references: [id], onDelete: SetNull)
}

model Notification {
  id           String      @id @default(uuid())
  type         String      // comment, translation_complete, task_failed, discovery
  title        String
  content      String
  articleId    String?
  articleTitle String?
  taskId       String?     // Link to AiTask for task-related notifications
  userId       String?
  isRead       Boolean     @default(false)
  createdAt    DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WikiDiscovery {
  id            String          @id @default(uuid())
  articleId     String?
  articleSlug   String
  articleLang   ArticleLanguage
  term          String
  type          String          // acronym | concept | theorem | tech | other
  definition    String          // 简短解释（仅参考）
  importance    Float           // 0-1
  status        DiscoveryStatus @default(pending)
  createdAt     DateTime        @default(now())
  approvedAt    DateTime?

  // AI generation result (Phase 5.5)
  wikiEntryId   String?         // Link to WikiEntry when generated
  wikiEntry     WikiEntry?      @relation(fields: [wikiEntryId], references: [id], onDelete: SetNull)
  failedReason  String?         // Reason if generation failed

  article       Article?        @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, term])
  @@index([articleId, term])
  @@index([status])
  @@index([articleId])
}

model AiUsageLog {
  id               String     @id @default(uuid())
  type             AiTaskType
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  createdAt        DateTime   @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
}
