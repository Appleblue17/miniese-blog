# 数据库
DATABASE_URL="postgresql://dev:devpass@localhost:5432/miniese"

# Redis
REDIS_URL="redis://localhost:6379"

# DeepSeek AI
DEEPSEEK_API_KEY="sk-xxx"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Resend（邮件服务，可选）
RESEND_API_KEY="re_xxx"

# 站点配置
SITE_NAME="Miniese's Blog"
SITE_URL="http://localhost:3000"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# OAuth（可选，不设置则对应 provider 不可用）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ICP备案号（可选，填入后显示在页脚）
ICP_BEIAN="沪ICP备2025xxxxxx号"

# 数据库（生产环境 Docker Compose 使用，由 docker-compose.prod.yml 读取）
POSTGRES_PASSWORD="change-me-to-a-strong-password"

# Redis（生产环境 Docker Compose 使用，由 docker-compose.prod.yml 读取）
REDIS_PASSWORD="change-me-to-a-strong-password"
